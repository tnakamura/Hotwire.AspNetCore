@model WireDrive.Models.OrderConfirmationViewModel
@{
    ViewData["Title"] = "Order Confirmation";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="alert alert-success">
                <h4 class="alert-heading">✅ Thank You for Your Order!</h4>
                <p>Your order has been received. A confirmation email has been sent.</p>
            </div>
            
            <div class="card">
                <div class="card-header">
                    <h5>Order Details</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Order Number:</dt>
                        <dd class="col-sm-8"><strong>#@Model.OrderId</strong></dd>
                        
                        <dt class="col-sm-4">Name:</dt>
                        <dd class="col-sm-8">@Model.CustomerName</dd>
                        
                        <dt class="col-sm-4">Email Address:</dt>
                        <dd class="col-sm-8">@Model.Email</dd>
                        
                        <dt class="col-sm-4">Status:</dt>
                        <dd class="col-sm-8"><span class="badge bg-success">Processing</span></dd>
                    </dl>
                </div>
            </div>
            
            <div class="alert alert-info mt-4">
                <strong>🎉 Turbo Drive Worked!</strong> 
                From form submission to redirect, the flow was accelerated by Turbo Drive.
                Music playback is also still running.
            </div>
            
            <div class="mt-4">
                <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Back to Home</a>
                <a class="btn btn-outline-primary" asp-controller="Products" asp-action="Index">View Other Products</a>
            </div>
        </div>
    </div>
</div>
