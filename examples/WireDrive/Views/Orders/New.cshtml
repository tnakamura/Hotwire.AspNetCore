@model WireDrive.Models.OrderViewModel
@{
    ViewData["Title"] = "New Order";
}

<div class="container">
    <h1 class="display-4 mb-4">New Order</h1>
    
    <div class="alert alert-info">
        <strong>📝 Turbo Drive Demo:</strong> This form is accelerated by Turbo Drive.
        Even after submitting the form, music playback continues.
    </div>
    
    <div class="row">
        <div class="col-md-8">
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label asp-for="CustomerName" class="form-label"></label>
                    <input asp-for="CustomerName" class="form-control" />
                    <span asp-validation-for="CustomerName" class="text-danger"></span>
                </div>
                
                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" type="email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                
                <div class="mb-3">
                    <label asp-for="Address" class="form-label"></label>
                    <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>
                
                <div class="mb-3">
                    <label asp-for="Comments" class="form-label"></label>
                    <textarea asp-for="Comments" class="form-control" rows="3"></textarea>
                </div>
                
                <input type="hidden" asp-for="ProductId" />
                
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary btn-lg">Confirm Order</button>
                    <a class="btn btn-secondary" asp-controller="Home" asp-action="Index">Cancel</a>
                </div>
            </form>
        </div>
        
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Order Flow</h5>
                    <ol>
                        <li>Enter the required information</li>
                        <li>Confirm your order</li>
                        <li>Receive a confirmation email</li>
                        <li>Product delivery</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
