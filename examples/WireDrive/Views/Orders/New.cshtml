@model WireDrive.Models.OrderViewModel
@{
    ViewData["Title"] = "新規注文";
}

<div class="container">
    <h1 class="display-4 mb-4">新規注文</h1>
    
    <div class="alert alert-info">
        <strong>📝 Turbo Drive Demo:</strong> このフォームは Turbo Drive により高速化されています。
        フォームを送信しても、音楽プレーヤーの再生は継続されます。
    </div>
    
    <div class="row">
        <div class="col-md-8">
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label asp-for="CustomerName" class="form-label"></label>
                    <input asp-for="CustomerName" class="form-control" />
                    <span asp-validation-for="CustomerName" class="text-danger"></span>
                </div>
                
                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" type="email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                
                <div class="mb-3">
                    <label asp-for="Address" class="form-label"></label>
                    <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>
                
                <div class="mb-3">
                    <label asp-for="Comments" class="form-label"></label>
                    <textarea asp-for="Comments" class="form-control" rows="3"></textarea>
                </div>
                
                <input type="hidden" asp-for="ProductId" />
                
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary btn-lg">注文を確定</button>
                    <a class="btn btn-secondary" asp-controller="Home" asp-action="Index">キャンセル</a>
                </div>
            </form>
        </div>
        
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">ご注文の流れ</h5>
                    <ol>
                        <li>必要事項を入力</li>
                        <li>注文を確定</li>
                        <li>確認メールを受信</li>
                        <li>商品をお届け</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
