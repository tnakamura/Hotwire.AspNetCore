@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to WireDrive</h1>
    <p class="lead">A Turbo Drive for ASP.NET Core demo application</p>
</div>

<div class="row mt-5">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">🚀 Fast Page Navigation</h5>
                <p class="card-text">
                    Turbo Drive makes page navigation much faster.
                    It delivers an SPA-like user experience.
                </p>
                <a class="btn btn-primary" asp-action="About">Learn More</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">🛍️ Product Catalog</h5>
                <p class="card-text">
                    A demo of product list and product detail pages.
                    Navigation between pages is smooth and fast.
                </p>
                <a class="btn btn-primary" asp-controller="Products" asp-action="Index">View Products</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">📝 Form Submission</h5>
                <p class="card-text">
                    Turbo Drive also accelerates form submissions.
                    Try it with the order form.
                </p>
                <a class="btn btn-primary" asp-controller="Orders" asp-action="New">Place an Order</a>
            </div>
        </div>
    </div>
</div>

<div class="mt-5">
    <h2>How to Use</h2>
    <ol>
        <li>Start playback in the music player</li>
        <li>Use the navigation bar links to move between pages</li>
        <li>Confirm that music playback continues</li>
        <li>Check network activity in your browser developer tools</li>
    </ol>
</div>
