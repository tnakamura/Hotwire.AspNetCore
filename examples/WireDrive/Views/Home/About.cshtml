@{
    ViewData["Title"] = "About";
}

<div class="text-center">
    <h1 class="display-4">About WireDrive</h1>
    <p class="lead">A demonstration application for Turbo Drive</p>
</div>

<div class="row mt-4">
    <div class="col-md-12">
        <h2>What is Turbo Drive?</h2>
        <p>
            Turbo Drive is a library that enhances links and form submissions with AJAX,
            preventing full-page reloads and making web applications faster.
        </p>
        
        <h3 class="mt-4">Features</h3>
        <ul>
            <li><strong>Fast page navigation</strong>: Replaces only the &lt;body&gt; content and reuses &lt;head&gt; resources</li>
            <li><strong>Progressive enhancement</strong>: Works even when JavaScript is disabled</li>
            <li><strong>Persistent elements</strong>: Keeps stateful elements across page transitions (such as a music player)</li>
            <li><strong>Easy integration</strong>: Can be added to existing ASP.NET Core apps with minimal effort</li>
        </ul>
        
        <h3 class="mt-4">Try it out</h3>
        <p>
            Click the links in the top navigation bar to move between pages.
            Start playback in the music player first, then navigate to confirm that playback continues.
        </p>
        
        <div class="alert alert-success mt-4">
            <strong>💡 Tip:</strong> Open your browser developer tools and check the Network tab
            to see which resources are requested during page navigation.
        </div>
    </div>
</div>

<div class="text-center mt-4">
    <a class="btn btn-primary" asp-controller="Products" asp-action="Index">View Product Catalog</a>
</div>
