@model WireDrive.Models.Product
@{
    ViewData["Title"] = Model.Name;
}

<div class="container">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Product Catalog</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>
    
    <div class="row mt-4">
        <div class="col-md-6">
            <img src="@Model.ImageUrl" class="img-fluid" alt="@Model.Name">
        </div>
        <div class="col-md-6">
            <h1 class="display-4">@Model.Name</h1>
            <p class="lead">@Model.Description</p>
            
            <div class="mt-4">
                <h3>Price: <span class="text-primary">$@Model.Price.ToString("F2")</span></h3>
            </div>
            
            <div class="mt-4">
                <h4>Product Features</h4>
                <ul>
                    <li>Fully integrated with ASP.NET Core</li>
                    <li>Easy setup</li>
                    <li>High performance</li>
                    <li>Supports progressive enhancement</li>
                </ul>
            </div>
            
            <div class="mt-4">
                <a class="btn btn-success btn-lg" asp-controller="Orders" asp-action="New" asp-route-productId="@Model.Id">Order Now</a>
                <a class="btn btn-secondary" asp-action="Index">Back to Catalog</a>
            </div>
        </div>
    </div>
    
    <div class="alert alert-success mt-4">
        <strong>✨ Turbo Drive is active:</strong> Navigation to this page was accelerated by Turbo Drive.
        In your browser developer tools, you can confirm that &lt;head&gt; resources are not requested again.
    </div>
</div>
