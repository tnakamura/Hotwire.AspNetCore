@model WireDrive.Models.Product
@{
    ViewData["Title"] = Model.Name;
}

<div class="container">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">ホーム</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">製品一覧</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>
    
    <div class="row mt-4">
        <div class="col-md-6">
            <img src="@Model.ImageUrl" class="img-fluid" alt="@Model.Name">
        </div>
        <div class="col-md-6">
            <h1 class="display-4">@Model.Name</h1>
            <p class="lead">@Model.Description</p>
            
            <div class="mt-4">
                <h3>価格: <span class="text-primary">$@Model.Price.ToString("F2")</span></h3>
            </div>
            
            <div class="mt-4">
                <h4>製品の特徴</h4>
                <ul>
                    <li>ASP.NET Core と完全統合</li>
                    <li>簡単なセットアップ</li>
                    <li>高パフォーマンス</li>
                    <li>プログレッシブエンハンスメント対応</li>
                </ul>
            </div>
            
            <div class="mt-4">
                <a class="btn btn-success btn-lg" asp-controller="Orders" asp-action="New" asp-route-productId="@Model.Id">今すぐ注文</a>
                <a class="btn btn-secondary" asp-action="Index">一覧に戻る</a>
            </div>
        </div>
    </div>
    
    <div class="alert alert-success mt-4">
        <strong>✨ Turbo Drive が動作中:</strong> このページへの遷移は Turbo Drive により高速化されています。
        ブラウザの開発者ツールで確認すると、&lt;head&gt; のリソースが再リクエストされていないことがわかります。
    </div>
</div>
