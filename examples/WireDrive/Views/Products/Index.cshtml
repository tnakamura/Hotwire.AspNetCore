@model IEnumerable<WireDrive.Models.Product>
@{
    ViewData["Title"] = "Products";
}

<div class="container">
    <h1 class="display-4 mb-4">Product Catalog</h1>
    
    <div class="alert alert-info">
        <strong>💡 Turbo Drive Demo:</strong> Even when you click a product and move to the details page,
        music playback continues. Notice how fast the page transition is.
    </div>
    
    <div class="row">
        @foreach (var product in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card">
                    <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name">
                    <div class="card-body">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text">@product.Description</p>
                        <p class="card-text">
                            <strong>Price:</strong> $@product.Price.ToString("F2")
                        </p>
                        <a class="btn btn-primary" asp-action="Details" asp-route-id="@product.Id">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
    
    <div class="mt-4">
        <a class="btn btn-secondary" asp-controller="Home" asp-action="Index">Back to Home</a>
    </div>
</div>
