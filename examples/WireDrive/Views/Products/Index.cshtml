@model IEnumerable<WireDrive.Models.Product>
@{
    ViewData["Title"] = "Products";
}

<div class="container">
    <h1 class="display-4 mb-4">製品一覧</h1>
    
    <div class="alert alert-info">
        <strong>💡 Turbo Drive Demo:</strong> 製品をクリックして詳細ページに移動しても、
        音楽プレーヤーの再生は継続されます。ページ遷移が非常に高速であることに注目してください。
    </div>
    
    <div class="row">
        @foreach (var product in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card">
                    <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name">
                    <div class="card-body">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text">@product.Description</p>
                        <p class="card-text">
                            <strong>価格:</strong> $@product.Price.ToString("F2")
                        </p>
                        <a class="btn btn-primary" asp-action="Details" asp-route-id="@product.Id">詳細を見る</a>
                    </div>
                </div>
            </div>
        }
    </div>
    
    <div class="mt-4">
        <a class="btn btn-secondary" asp-controller="Home" asp-action="Index">ホームに戻る</a>
    </div>
</div>
