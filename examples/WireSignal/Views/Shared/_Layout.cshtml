<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WireSignal</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <!-- SignalR Client Library -->
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@latest/dist/browser/signalr.min.js"></script>
    
    <!-- Turbo -->
    <script src="https://cdn.jsdelivr.net/npm/@@hotwired/turbo@@latest"></script>
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="container">
                <a class="navbar-brand" href="/">WireSignal</a>
                <ul class="nav-links">
                    <li><a href="/">Home</a></li>
                    <li><a href="/Notifications">Notifications</a></li>
                    <li><a href="/Chat">Chat</a></li>
                </ul>
            </div>
        </nav>
    </header>
    
    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="container">
            <p>&copy; 2026 - WireSignal - Real-time Turbo Streams with SignalR</p>
        </div>
    </footer>

    <!-- Turbo SignalR Integration -->
    <script src="~/js/turbo-signalr.js"></script>
    
    @RenderSection("Scripts", required: false)
</body>
</html>
