@{
    ViewData["Title"] = "Notifications";
}

<h1>Real-time Notifications</h1>
<p>Send a notification and see it appear instantly for all connected users!</p>

<div class="notification-demo">
    <div class="notification-form">
        <h3>Send Notification</h3>
        <form method="post" action="/Notifications/Create">
            <div class="form-group">
                <label for="title">Title:</label>
                <input type="text" id="title" name="title" class="form-control" required />
            </div>
            
            <div class="form-group">
                <label for="message">Message:</label>
                <textarea id="message" name="message" class="form-control" rows="3" required></textarea>
            </div>
            
            <div class="form-group">
                <label for="type">Type:</label>
                <select id="type" name="type" class="form-control">
                    <option value="info">Info</option>
                    <option value="success">Success</option>
                    <option value="warning">Warning</option>
                    <option value="error">Error</option>
                </select>
            </div>
            
            <button type="submit" class="btn btn-primary">Send Notification</button>
        </form>
    </div>
    
    <div class="notifications-display">
        <h3>Live Notifications</h3>
        <div id="notifications" class="notifications-list">
            <!-- Notifications will appear here -->
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Subscribe to notifications channel
    const turboSignalR = new TurboSignalR();
    turboSignalR.start().then(() => {
        turboSignalR.subscribe('notifications');
        console.log('Subscribed to notifications channel');
    });
    
    // Show a visual indicator when new notifications arrive
    document.addEventListener('turbo-signalr:streamReceived', (event) => {
        console.log('Notification received!');
    });
</script>
}
